# Copy to `.env` and fill in. Never commit the real .env.

# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- Database (Neon / PostgreSQL) ---
# App uses the POOLED endpoint (host contains "-pooler"). The +asyncpg driver and
# any ?sslmode=require are handled automatically by app/db.py.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
# Optional: a DIRECT (non-pooled) endpoint for Alembic migrations. Falls back to DATABASE_URL.
ALEMBIC_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require

# --- Telegram bot (Phase 3) ---
BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=

# --- Solver ---
SOLVER_TIME_LIMIT_SECONDS=10
SOLVER_RANDOM_SEED=42
SOLVER_NUM_WORKERS=8

# --- Scheduling ---
DEFAULT_TIMEZONE=Asia/Kolkata
